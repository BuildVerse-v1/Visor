# Server configuration
PORT=3000
NODE_ENV=development

# Database configuration
# Connect to your online MongoDB Atlas cloud cluster (e.g. mongodb+srv://...)
MONGODB_URI=your_mongodb_atlas_connection_string

# MiniMax API configuration (OpenAI-compatible)
# Sign up at MiniMax Platform to get your API key
MINIMAX_API_KEY=your_minimax_api_key

# Deepgram Speech Service keys
# Get these keys from console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# Security tokens (JWT)
JWT_SECRET=your_jwt_signing_secret_min_32_characters
JWT_EXPIRES_IN=24h
